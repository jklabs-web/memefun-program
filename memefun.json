          },
          {
            "name": "real_token_reserves",
            "docs": [
              "Real tokens remaining on the curve."
            ],
            "type": "u64"
          },
          {
            "name": "token_total_supply",
            "docs": [
              "Total token supply minted at creation."
            ],
            "type": "u64"
          },
          {
            "name": "created_slot",
            "docs": [
              "Slot at which this token was created."
            ],
            "type": "u64"
          },
          {
            "name": "bump",
            "docs": [
              "PDA bump seed."
            ],
            "type": "u8"
          },
          {
            "name": "mcap_high_since",
            "docs": [
              "Unix timestamp at which REAL LIQUIDITY (`real_sol_reserves`) first reached the",
              "fee-tier threshold and has stayed at/above it since; 0 whenever a trade observes",
              "it back below the threshold. Drives the creator-fee latch dwell timer.",
              "(Name kept for account-layout/IDL stability; it tracks real liquidity, not mcap.)"
            ],
            "type": "i64"
          },
          {
            "name": "creator_fees_ended",
            "docs": [
              "Once true, the creator fee is 0 forever — even if real liquidity later falls",
              "back below the threshold. Set after real liquidity holds >= threshold",
              "continuously for CREATOR_FEE_LATCH_DELAY_SECONDS. One-time; never unset."
            ],
            "type": "bool"
          },
          {
            "name": "creator_fees_owed",
            "docs": [
              "Creator fees accrued (WSOL lamports) and not yet claimed. Fees accrue",
              "in-vault rather than being pushed per-trade so a Jupiter `swap` CPI never",
              "has to create/fund a per-trade fee account. Claimed via `claim_creator_fees`."
            ],
            "type": "u64"
          },
          {
            "name": "protocol_fees_owed",
            "docs": [
              "Protocol fees accrued (WSOL lamports) and not yet claimed by the treasury.",
              "Claimed via `claim_protocol_fees`. See [[creator_fees_owed]]."
            ],
            "type": "u64"
          },
          {
            "name": "config",
            "docs": [
              "Curve + fee config, COPIED from `Global.config` at creation and frozen for",
              "this curve's lifetime — so its quote math (buy/sell exact-inverse) never",
              "changes under it, and an admin retuning the global default never reprices",
              "it. Integrators read the exact quote params per mint from here."
            ],
            "type": {
              "defined": {
                "name": "CurveConfig"
              }
            }
          }
        ]
      }
