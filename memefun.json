    {
      "name": "CurveConfig",
      "docs": [
        "Curve + fee configuration.",
        "",
        "Lives on [`Global`](super::Global) as the **platform default** and is",
        "SNAPSHOTTED onto each [`BondingCurve`](super::BondingCurve) at creation. So an",
        "admin can retune the default for *new* launches via `set_curve_config` without",
        "ever repricing a live curve — each curve keeps the copy it was born with."
      ],
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "initial_virtual_sol",
            "docs": [
              "Launch phantom SOL (V0) — the pricing reserve at `real_sol = 0`."
            ],
            "type": "u64"
          },
          {
            "name": "drain_alpha_bps",
            "docs": [
              "α-drain rate in basis points (α = drain_alpha_bps / 10_000; phantom drained per real SOL)."
            ],
            "type": "u16"
          },
          {
            "name": "fee_tier_threshold_lamports",
            "docs": [
              "Real SOL reserves (lamports) at/above which fees switch to the high tier.",
              "Compared against `real_sol_reserves` (actual pool liquidity), NOT market cap."
            ],
            "type": "u64"
          },
          {
            "name": "creator_fee_latch_delay_seconds",
            "docs": [
              "Seconds real liquidity must hold ≥ threshold before the creator-fee cutoff latches."
            ],
            "type": "i64"
          },
          {
            "name": "creator_fee_bps_low",
            "docs": [
              "Fee schedule (bps) — low tier (real liq < threshold) then high tier (≥)."
            ],
            "type": "u16"
          },
          {
            "name": "protocol_fee_bps_low",
            "type": "u16"
          },
          {
            "name": "lp_fee_bps_low",
            "type": "u16"
          },
